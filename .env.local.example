# Supabase Configuration
# 1. Go to https://supabase.com and create a new project
# 2. Copy these from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Moderators who can verify campsites on Bitcoin (comma-separated emails)
# Leave empty for MVP: any signed-in user can verify
NEXT_PUBLIC_MODERATOR_EMAILS=admin@rvchain.app,mod@rvchain.app

# USDC receive addresses for booking checkout (per chain)
NEXT_PUBLIC_USDC_BASE_ADDRESS=0xYourBaseUsdcAddress
NEXT_PUBLIC_USDC_ETH_ADDRESS=0xYourEthereumUsdcAddress
NEXT_PUBLIC_USDC_SOL_ADDRESS=YourSolanaUsdcAddress

# Forgot password / OTP (Supabase Dashboard > Authentication > Providers)
# - Email: enable Email provider and "Email OTP" (or magic link + OTP template)
# - SMS: enable Phone provider and configure Twilio/MessageBird/etc.

# After creating tables and enabling realtime in the Supabase dashboard,
# restart your dev server (npm run dev) so env vars are loaded.